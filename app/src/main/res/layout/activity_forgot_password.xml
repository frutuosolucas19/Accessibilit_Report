<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/azul_login"
    tools:ignore="Overdraw"
    tools:context=".activities.ForgotPasswordActivity">

    <ImageView
        android:id="@+id/imageViewLogoForgot"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_marginTop="36dp"
        android:importantForAccessibility="no"
        android:src="@drawable/novalogo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textViewTituloAppForgot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:accessibilityHeading="true"
        android:text="@string/accessibility_report"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imageViewLogoForgot" />

    <TextView
        android:id="@+id/textViewTituloRecuperacao"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:accessibilityHeading="true"
        android:text="@string/recuperar_senha_titulo"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textViewTituloAppForgot" />

    <EditText
        android:id="@+id/editTextEmailRecuperacao"
        style="@style/Edit_text"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:autofillHints="emailAddress"
        android:layout_marginTop="32dp"
        android:backgroundTint="@color/white"
        android:drawableEnd="@drawable/ic_email"
        android:hint="@string/email"
        android:inputType="textEmailAddress"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="@color/black"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textViewTituloRecuperacao"
        app:layout_constraintWidth_percent="0.85" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/buttonEnviarTrocaSenha"
        style="@style/Button_Login"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="36dp"
        android:background="@drawable/button_white_rounded"
        android:text="@string/enviar_troca_senha"
        android:textColor="@color/azul_login"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="@id/editTextEmailRecuperacao"
        app:layout_constraintStart_toStartOf="@id/editTextEmailRecuperacao"
        app:layout_constraintTop_toBottomOf="@id/editTextEmailRecuperacao" />

</androidx.constraintlayout.widget.ConstraintLayout>
