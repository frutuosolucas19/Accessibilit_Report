<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="4dp"
    android:background="@drawable/borda"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Cabeçalho da pergunta (sempre visível) -->
    <TextView
        android:id="@+id/tv_pergunta_titulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_pergunta_conteudo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="3"
        android:textColor="#555555"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_pergunta_total_respostas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/azul_login"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_expandir"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="@string/forum_ver_respostas"
            android:textColor="@color/azul_login"
            android:textSize="12sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_excluir_pergunta"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_excluir"
            android:textColor="#B00020"
            app:strokeColor="#B00020" />

    </LinearLayout>

    <!-- Seção expansível: respostas e campo de resposta -->
    <LinearLayout
        android:id="@+id/ll_respostas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/pb_respostas"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:importantForAccessibility="no"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_sem_respostas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/forum_sem_respostas"
            android:textColor="#888888"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- Lista de respostas (views adicionadas dinamicamente) -->
        <LinearLayout
            android:id="@+id/ll_lista_respostas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- Campo para nova resposta -->
        <EditText
            android:id="@+id/edt_nova_resposta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/borda"
            android:hint="@string/item_resposta_hint"
            android:importantForAutofill="no"
            android:inputType="textMultiLine"
            android:minLines="1"
            android:padding="8dp"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btn_enviar_resposta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="4dp"
            android:backgroundTint="@color/azul_login"
            android:text="@string/forum_enviar"
            android:textColor="@android:color/white"
            android:textSize="13sp" />

    </LinearLayout>

</LinearLayout>
