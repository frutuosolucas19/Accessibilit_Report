<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:padding="12dp"
    android:orientation="vertical"
    android:screenReaderFocusable="true"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/tv_titulo"
        android:textStyle="bold"
        android:textSize="16sp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/t_tulo"/>

    <TextView
        android:id="@+id/tv_endereco"
        android:layout_marginTop="2dp"
        android:textSize="14sp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/endere_o"/>

    <TextView
        android:id="@+id/tv_problema"
        android:layout_marginTop="4dp"
        android:textSize="14sp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/problema"/>

    <TextView
        android:id="@+id/tv_data"
        android:layout_marginTop="2dp"
        android:textSize="12sp"
        android:textColor="#757575"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/criado_em"/>

    <ImageView
        android:id="@+id/iv_imagem"
        android:layout_marginTop="8dp"
        android:adjustViewBounds="true"
        android:contentDescription="@string/item_denuncia_imagem"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="180dp"/>
</LinearLayout>
