<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Acessibilit_Report">
        <activity
            android:name=".activities.AdminActivity"
            android:exported="false"
            android:theme="@style/Theme.Acessibilit_Report" />
        <activity
            android:name=".activities.AdminManageReportsActivity"
            android:exported="false"
            android:theme="@style/Theme.Acessibilit_Report" />
        <activity
            android:name=".activities.AdminManageUsersActivity"
            android:exported="false"
            android:theme="@style/Theme.Acessibilit_Report" />
        <activity
            android:name=".activities.QuestionRegistrationActivity"
            android:exported="false">
            <meta-data
                android:name="android.app.lib_name"
                android:value="" />
        </activity>
        <activity
            android:name=".activities.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".activities.ForgotPasswordActivity" />
        <activity android:name=".activities.ResetPasswordActivity" />
        <activity android:name=".activities.UserRegistrationActivity" />
        <activity android:name=".activities.MenuActivity" />
    </application>

</manifest>

